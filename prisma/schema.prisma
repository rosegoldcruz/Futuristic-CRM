generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum ContactStatus {
  ACTIVE
  INVALID
  SUPPRESSED
  BOUNCED
  UNSUBSCRIBED
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  READY_FOR_REVIEW
  DRY_RUN_PREPARED
  EXPORTED_TO_SEND_LAYER
  ACTIVE_EXTERNAL
  PAUSED
  COMPLETED
  ARCHIVED
}

enum QueueStatus {
  QUEUED
  DRY_RUN_PREPARED
  SKIPPED_SUPPRESSED
  SKIPPED_INVALID
  SKIPPED_DUPLICATE
  EXPORTED
  API_PENDING
  API_SYNCED
  API_FAILED
  FAILED
}

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE
  COMPLAINT
  MANUAL
  INVALID
  DUPLICATE
  DO_NOT_CONTACT
}

enum SendLayer {
  DRY_RUN
  SMARTLEAD
  INSTANTLY
}

enum SendLayerSyncStatus {
  NOT_CONNECTED
  DRY_RUN
  READY_TO_EXPORT
  EXPORTED
  API_PENDING
  API_SYNCED
  API_FAILED
}

enum AutomationStatus {
  NOT_CONFIGURED
  ENABLED
  DISABLED
  SENT
  FAILED
  RECEIVED
  PROCESSED
}

enum AutomationDirection {
  OUTBOUND
  INBOUND
}

enum ValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET_REF
}

model User {
  id            String     @id @default(cuid())
  zitadelUserId String?    @unique
  email         String     @unique
  name        String?
  role        UserRole   @default(USER)
  status      UserStatus @default(PENDING)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  domain    String?
  industry  String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  source    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
}

model Contact {
  id          String            @id @default(cuid())
  email       String            @unique
  firstName   String?
  lastName    String?
  fullName    String?
  phone       String?
  title       String?
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  source      String?
  status      ContactStatus     @default(ACTIVE)
  tags        String[]          @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  leadLists   LeadListContact[]
  queueItems  CampaignQueueItem[]
  events      CampaignEvent[]

  @@index([companyId])
}

model LeadList {
  id          String            @id @default(cuid())
  name        String
  description String?
  source      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  contacts    LeadListContact[]
  campaigns   Campaign[]
}

model LeadListContact {
  id        String   @id @default(cuid())
  listId    String
  contactId String
  createdAt DateTime @default(now())
  list      LeadList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([contactId])
}

model EmailTemplate {
  id         String              @id @default(cuid())
  name       String
  subject    String
  body       String
  variables  Json?
  status     TemplateStatus      @default(DRAFT)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  campaigns  Campaign[]
  queueItems CampaignQueueItem[]
}

model Campaign {
  id               String              @id @default(cuid())
  name             String
  description      String?
  status           CampaignStatus      @default(DRAFT)
  listId           String?
  list             LeadList?           @relation(fields: [listId], references: [id], onDelete: SetNull)
  templateId       String?
  template         EmailTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sendLayer        SendLayer           @default(DRY_RUN)
  fromName         String?
  fromEmail        String?
  replyToEmail     String?
  dailyLimit       Int?
  sendWindowStart  String?
  sendWindowEnd    String?
  timezone         String?
  complianceFooter String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  queueItems       CampaignQueueItem[]
  events           CampaignEvent[]
  exports          SendLayerExport[]

  @@index([listId])
  @@index([templateId])
}

model CampaignQueueItem {
  id           String         @id @default(cuid())
  campaignId   String
  contactId    String
  templateId   String?
  toEmail      String
  fromEmail    String?
  replyToEmail String?
  subject      String?
  body         String?
  status       QueueStatus    @default(QUEUED)
  scheduledAt  DateTime?
  preparedAt   DateTime?
  exportedAt   DateTime?
  externalId   String?
  failureReason String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  events       CampaignEvent[]

  @@unique([campaignId, contactId])
  @@index([contactId])
  @@index([templateId])
}

model CampaignEvent {
  id          String             @id @default(cuid())
  queueItemId String?
  campaignId  String?
  contactId   String?
  type        String
  metadata    Json?
  createdAt   DateTime           @default(now())
  queueItem   CampaignQueueItem? @relation(fields: [queueItemId], references: [id], onDelete: SetNull)
  campaign    Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact     Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([queueItemId])
  @@index([campaignId])
  @@index([contactId])
}

model Suppression {
  id        String            @id @default(cuid())
  email     String            @unique
  reason    SuppressionReason
  source    String?
  createdAt DateTime          @default(now())
}

model SendLayerExport {
  id         String              @id @default(cuid())
  campaignId String?
  provider   SendLayer
  status     SendLayerSyncStatus @default(DRY_RUN)
  filePath   String?
  metadata   Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  campaign   Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([campaignId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Setting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String?
  valueType   ValueType @default(STRING)
  isSecret    Boolean   @default(false)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AutomationEvent {
  id         String           @id @default(cuid())
  eventType  String
  entityType String?
  entityId   String?
  status     AutomationStatus @default(RECEIVED)
  payload    Json?
  response   Json?
  error      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model AutomationWorkflow {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  direction      AutomationDirection
  status         AutomationStatus    @default(NOT_CONFIGURED)
  n8nWebhookPath String?
  description    String?
  lastHeartbeatAt DateTime?
  lastRunAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model EmailCompanyOp {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  domain      String?
  website     String?
  phone       String?
  industry    String?
  source      String?
  status      String           @default("active")
  companyType String?          @map("company_type")
  addressLine1 String?         @map("address_line1")
  addressLine2 String?         @map("address_line2")
  city        String?
  state       String?
  postalCode  String?          @map("postal_code")
  country     String?          @default("US")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  contacts    EmailContactOp[]
  leads       LeadOp[]

  @@index([domain])
  @@index([name])
  @@map("email_companies")
}

model EmailContactOp {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String?                    @map("company_id") @db.Uuid
  firstName   String?                    @map("first_name")
  lastName    String?                    @map("last_name")
  fullName    String?                    @map("full_name")
  email       String                     @unique
  phone       String?
  title       String?
  source      String?
  status      String                     @default("active")
  consentStatus String                   @default("unknown") @map("consent_status")
  notes       String?
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     EmailCompanyOp?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  listMembers EmailListMemberOp[]
  recipients  EmailCampaignRecipientOp[]
  events      EmailEventOp[]
  inbound     EmailInboundMessageOp[]
  leads       LeadOp[]

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@map("email_contacts")
}

model EmailListOp {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String              @unique
  description String?
  type        String              @default("static")
  status      String              @default("active")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  members     EmailListMemberOp[]
  campaigns   EmailCampaignOp[]

  @@map("email_lists")
}

model EmailListMemberOp {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId    String         @map("list_id") @db.Uuid
  contactId String         @map("contact_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  list      EmailListOp    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   EmailContactOp @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([contactId])
  @@map("email_list_members")
}

model EmailTemplateOp {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  subject   String
  preheader String?
  bodyHtml  String?           @map("body_html")
  bodyText  String?           @map("body_text")
  body      String?
  category  String?
  status    String            @default("draft")
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaigns EmailCampaignOp[]

  @@map("email_templates")
}

model EmailCampaignOp {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  templateId  String?                    @map("template_id") @db.Uuid
  listId      String?                    @map("list_id") @db.Uuid
  subjectOverride String?                @map("subject_override")
  status      String                     @default("draft")
  scheduledAt DateTime?                  @map("scheduled_at") @db.Timestamptz(6)
  approvedAt  DateTime?                  @map("approved_at") @db.Timestamptz(6)
  sentAt      DateTime?                  @map("sent_at") @db.Timestamptz(6)
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  template    EmailTemplateOp?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  list        EmailListOp?               @relation(fields: [listId], references: [id], onDelete: SetNull)
  recipients  EmailCampaignRecipientOp[]
  events      EmailEventOp[]

  @@index([templateId])
  @@index([listId])
  @@index([status])
  @@map("email_campaigns")
}

model EmailCampaignRecipientOp {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String          @map("campaign_id") @db.Uuid
  contactId           String          @map("contact_id") @db.Uuid
  status              String          @default("draft_ready")
  personalizedSubject String?         @map("personalized_subject")
  personalizedBody    String?         @map("personalized_body")
  personalizedHtml    String?         @map("personalized_html")
  personalizedText    String?         @map("personalized_text")
  sentAt              DateTime?       @map("sent_at") @db.Timestamptz(6)
  repliedAt           DateTime?       @map("replied_at") @db.Timestamptz(6)
  lastError           String?         @map("last_error")
  providerMessageId   String?         @map("provider_message_id")
  nextFollowUpAt      DateTime?       @map("next_follow_up_at") @db.Timestamptz(6)
  notes               String?
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaign            EmailCampaignOp @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact             EmailContactOp  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events              EmailEventOp[]

  @@unique([campaignId, contactId])
  @@index([contactId])
  @@index([status])
  @@map("email_campaign_recipients")
}

model EmailEventOp {
  id          String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String?                   @map("campaign_id") @db.Uuid
  queueId     String?                   @map("queue_id") @db.Uuid
  recipientId String?                   @map("recipient_id") @db.Uuid
  contactId   String?                   @map("contact_id") @db.Uuid
  eventType   String                    @map("event_type")
  metadata    Json                      @default("{}")
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign    EmailCampaignOp?          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient   EmailCampaignRecipientOp? @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  contact     EmailContactOp?           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([queueId])
  @@index([recipientId])
  @@index([contactId])
  @@index([eventType])
  @@map("email_events")
}

model EmailQueueOp {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId        String?   @map("campaign_id") @db.Uuid
  contactId         String?   @map("contact_id") @db.Uuid
  recipientId       String?   @map("recipient_id") @db.Uuid
  recipientEmail    String    @map("recipient_email")
  subject           String
  bodyHtml          String    @map("body_html")
  bodyText          String?   @map("body_text")
  status            String    @default("queued")
  provider          String?
  providerMessageId String?   @map("provider_message_id")
  attemptCount      Int       @default(0) @map("attempt_count")
  maxAttempts       Int       @default(3) @map("max_attempts")
  nextAttemptAt     DateTime? @map("next_attempt_at") @db.Timestamptz(6)
  lastError         String?   @map("last_error")
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([campaignId])
  @@index([contactId])
  @@index([recipientId])
  @@index([status])
  @@index([nextAttemptAt])
  @@map("email_queue")
}

model EmailProviderAccountOp {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  provider     String
  fromEmail    String   @map("from_email")
  fromName     String?  @map("from_name")
  replyToEmail String?  @map("reply_to_email")
  status       String   @default("inactive")
  config       Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([provider])
  @@index([status])
  @@map("email_provider_accounts")
}

model EmailSuppressionOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  reason    String
  source    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("email_suppressions")
}

model EmailInboundMessageOp {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId  String?         @map("contact_id") @db.Uuid
  fromEmail  String          @map("from_email")
  subject    String?
  body       String?
  receivedAt DateTime?       @map("received_at") @db.Timestamptz(6)
  rawPayload Json?           @map("raw_payload")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  contact    EmailContactOp? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@map("email_inbound_messages")
}

model EmailSendSettingsOp {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLimit          Int      @default(25) @map("daily_limit")
  batchSize           Int      @default(5) @map("batch_size")
  minSecondsBetweenSends Int   @default(60) @map("min_seconds_between_sends")
  enabled             Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("email_send_settings")
}

model LeadOp {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String?          @map("company_id") @db.Uuid
  contactId       String?          @map("contact_id") @db.Uuid
  firstName       String?          @map("first_name")
  lastName        String?          @map("last_name")
  email           String?
  phone           String?
  companyName     String?          @map("company_name")
  title           String?
  source          String?
  campaign        String?
  status          String           @default("new")
  interestLevel   String           @default("unknown") @map("interest_level")
  assignedTo      String?          @map("assigned_to")
  estimatedValue  Decimal?         @map("estimated_value") @db.Decimal(12, 2)
  lastContactedAt DateTime?        @map("last_contacted_at") @db.Timestamptz(6)
  nextFollowUpAt  DateTime?        @map("next_follow_up_at") @db.Timestamptz(6)
  notes           String?
  archivedAt      DateTime?        @map("archived_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  company         EmailCompanyOp?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         EmailContactOp?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  events          LeadEventOp[]
  notesList       LeadNoteOp[]
  assignments     LeadAssignmentOp[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([source])
  @@index([campaign])
  @@index([assignedTo])
  @@index([interestLevel])
  @@index([nextFollowUpAt])
  @@index([createdAt])
  @@index([companyId])
  @@index([contactId])
  @@map("leads")
}

model LeadEventOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lead      LeadOp   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([eventType])
  @@index([createdAt])
  @@map("lead_events")
}

model LeadNoteOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  body      String
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lead      LeadOp   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
  @@map("lead_notes")
}

model LeadAssignmentOp {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  assignedTo String   @map("assigned_to")
  assignedBy String?  @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lead       LeadOp   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("lead_assignments")
}

model FileFolderOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String
  path      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([parentId, name])
  @@index([parentId])
  @@map("file_folders")
}

model FileRecordOp {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  folderId      String?  @map("folder_id") @db.Uuid
  ownerType     String?  @map("owner_type")
  ownerId       String?  @map("owner_id") @db.Uuid
  originalName  String   @map("original_name")
  storageName   String   @map("storage_name")
  mimeType      String?  @map("mime_type")
  sizeBytes     BigInt   @default(0) @map("size_bytes")
  storageDriver String   @map("storage_driver")
  storagePath   String   @map("storage_path")
  status        String   @default("active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([folderId])
  @@index([ownerType, ownerId])
  @@index([status])
  @@map("files")
}

model FileEventOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId    String?  @map("file_id") @db.Uuid
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([fileId])
  @@index([eventType])
  @@map("file_events")
}

model AutomationRunOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source    String
  action    String
  status    String   @default("pending")
  input     Json?
  output    Json?
  error     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([source])
  @@index([action])
  @@index([status])
  @@map("automation_runs")
}

model AuditEventOp {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  action      String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_events")
}

model AppSettingOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("app_settings")
}
