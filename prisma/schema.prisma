generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum ContactStatus {
  ACTIVE
  INVALID
  SUPPRESSED
  BOUNCED
  UNSUBSCRIBED
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  READY_FOR_REVIEW
  DRY_RUN_PREPARED
  EXPORTED_TO_SEND_LAYER
  ACTIVE_EXTERNAL
  PAUSED
  COMPLETED
  ARCHIVED
}

enum QueueStatus {
  QUEUED
  DRY_RUN_PREPARED
  SKIPPED_SUPPRESSED
  SKIPPED_INVALID
  SKIPPED_DUPLICATE
  EXPORTED
  API_PENDING
  API_SYNCED
  API_FAILED
  FAILED
}

enum SuppressionReason {
  UNSUBSCRIBE
  BOUNCE
  COMPLAINT
  MANUAL
  INVALID
  DUPLICATE
  DO_NOT_CONTACT
}

enum SendLayer {
  DRY_RUN
  SMARTLEAD
  INSTANTLY
}

enum SendLayerSyncStatus {
  NOT_CONNECTED
  DRY_RUN
  READY_TO_EXPORT
  EXPORTED
  API_PENDING
  API_SYNCED
  API_FAILED
}

enum AutomationStatus {
  NOT_CONFIGURED
  ENABLED
  DISABLED
  SENT
  FAILED
  RECEIVED
  PROCESSED
}

enum AutomationDirection {
  OUTBOUND
  INBOUND
}

enum ValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET_REF
}

model User {
  id            String     @id @default(cuid())
  zitadelUserId String?    @unique
  email         String     @unique
  name        String?
  role        UserRole   @default(USER)
  status      UserStatus @default(PENDING)
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  domain    String?
  industry  String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  source    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  contacts  Contact[]
}

model Contact {
  id          String            @id @default(cuid())
  email       String            @unique
  firstName   String?
  lastName    String?
  fullName    String?
  phone       String?
  title       String?
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  source      String?
  status      ContactStatus     @default(ACTIVE)
  tags        String[]          @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  leadLists   LeadListContact[]
  queueItems  CampaignQueueItem[]
  events      CampaignEvent[]

  @@index([companyId])
}

model LeadList {
  id          String            @id @default(cuid())
  name        String
  description String?
  source      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  contacts    LeadListContact[]
  campaigns   Campaign[]
}

model LeadListContact {
  id        String   @id @default(cuid())
  listId    String
  contactId String
  createdAt DateTime @default(now())
  list      LeadList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([contactId])
}

model EmailTemplate {
  id         String              @id @default(cuid())
  name       String
  subject    String
  body       String
  variables  Json?
  status     TemplateStatus      @default(DRAFT)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  campaigns  Campaign[]
  queueItems CampaignQueueItem[]
}

model Campaign {
  id               String              @id @default(cuid())
  name             String
  description      String?
  status           CampaignStatus      @default(DRAFT)
  listId           String?
  list             LeadList?           @relation(fields: [listId], references: [id], onDelete: SetNull)
  templateId       String?
  template         EmailTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sendLayer        SendLayer           @default(DRY_RUN)
  fromName         String?
  fromEmail        String?
  replyToEmail     String?
  dailyLimit       Int?
  sendWindowStart  String?
  sendWindowEnd    String?
  timezone         String?
  complianceFooter String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  queueItems       CampaignQueueItem[]
  events           CampaignEvent[]
  exports          SendLayerExport[]

  @@index([listId])
  @@index([templateId])
}

model CampaignQueueItem {
  id           String         @id @default(cuid())
  campaignId   String
  contactId    String
  templateId   String?
  toEmail      String
  fromEmail    String?
  replyToEmail String?
  subject      String?
  body         String?
  status       QueueStatus    @default(QUEUED)
  scheduledAt  DateTime?
  preparedAt   DateTime?
  exportedAt   DateTime?
  externalId   String?
  failureReason String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  events       CampaignEvent[]

  @@unique([campaignId, contactId])
  @@index([contactId])
  @@index([templateId])
}

model CampaignEvent {
  id          String             @id @default(cuid())
  queueItemId String?
  campaignId  String?
  contactId   String?
  type        String
  metadata    Json?
  createdAt   DateTime           @default(now())
  queueItem   CampaignQueueItem? @relation(fields: [queueItemId], references: [id], onDelete: SetNull)
  campaign    Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact     Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([queueItemId])
  @@index([campaignId])
  @@index([contactId])
}

model Suppression {
  id        String            @id @default(cuid())
  email     String            @unique
  reason    SuppressionReason
  source    String?
  createdAt DateTime          @default(now())
}

model SendLayerExport {
  id         String              @id @default(cuid())
  campaignId String?
  provider   SendLayer
  status     SendLayerSyncStatus @default(DRY_RUN)
  filePath   String?
  metadata   Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  campaign   Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([campaignId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model Setting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String?
  valueType   ValueType @default(STRING)
  isSecret    Boolean   @default(false)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AutomationEvent {
  id         String           @id @default(cuid())
  eventType  String
  entityType String?
  entityId   String?
  status     AutomationStatus @default(RECEIVED)
  payload    Json?
  response   Json?
  error      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model AutomationWorkflow {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  direction      AutomationDirection
  status         AutomationStatus    @default(NOT_CONFIGURED)
  n8nWebhookPath String?
  description    String?
  lastHeartbeatAt DateTime?
  lastRunAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model EmailCompanyOp {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  website     String?
  phone       String?
  industry    String?
  companyType String?          @map("company_type")
  addressLine1 String?         @map("address_line1")
  addressLine2 String?         @map("address_line2")
  city        String?
  state       String?
  postalCode  String?          @map("postal_code")
  country     String?          @default("US")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  contacts    EmailContactOp[]

  @@map("email_companies")
}

model EmailContactOp {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String?                    @map("company_id") @db.Uuid
  firstName   String?                    @map("first_name")
  lastName    String?                    @map("last_name")
  fullName    String?                    @map("full_name")
  email       String                     @unique
  phone       String?
  title       String?
  source      String?
  status      String                     @default("active")
  notes       String?
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     EmailCompanyOp?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  listMembers EmailListMemberOp[]
  recipients  EmailCampaignRecipientOp[]
  events      EmailEventOp[]
  inbound     EmailInboundMessageOp[]

  @@index([companyId])
  @@index([status])
  @@map("email_contacts")
}

model EmailListOp {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  members     EmailListMemberOp[]
  campaigns   EmailCampaignOp[]

  @@map("email_lists")
}

model EmailListMemberOp {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listId    String         @map("list_id") @db.Uuid
  contactId String         @map("contact_id") @db.Uuid
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  list      EmailListOp    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact   EmailContactOp @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
  @@index([contactId])
  @@map("email_list_members")
}

model EmailTemplateOp {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  subject   String
  bodyHtml  String?           @map("body_html")
  bodyText  String?           @map("body_text")
  body      String?
  category  String?
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaigns EmailCampaignOp[]

  @@map("email_templates")
}

model EmailCampaignOp {
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  templateId  String?                    @map("template_id") @db.Uuid
  listId      String?                    @map("list_id") @db.Uuid
  status      String                     @default("draft")
  scheduledAt DateTime?                  @map("scheduled_at") @db.Timestamptz(6)
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  template    EmailTemplateOp?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  list        EmailListOp?               @relation(fields: [listId], references: [id], onDelete: SetNull)
  recipients  EmailCampaignRecipientOp[]
  events      EmailEventOp[]

  @@index([templateId])
  @@index([listId])
  @@index([status])
  @@map("email_campaigns")
}

model EmailCampaignRecipientOp {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String          @map("campaign_id") @db.Uuid
  contactId           String          @map("contact_id") @db.Uuid
  status              String          @default("draft_ready")
  personalizedSubject String?         @map("personalized_subject")
  personalizedBody    String?         @map("personalized_body")
  personalizedHtml    String?         @map("personalized_html")
  personalizedText    String?         @map("personalized_text")
  sentAt              DateTime?       @map("sent_at") @db.Timestamptz(6)
  repliedAt           DateTime?       @map("replied_at") @db.Timestamptz(6)
  lastError           String?         @map("last_error")
  providerMessageId   String?         @map("provider_message_id")
  nextFollowUpAt      DateTime?       @map("next_follow_up_at") @db.Timestamptz(6)
  notes               String?
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaign            EmailCampaignOp @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact             EmailContactOp  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events              EmailEventOp[]

  @@unique([campaignId, contactId])
  @@index([contactId])
  @@index([status])
  @@map("email_campaign_recipients")
}

model EmailEventOp {
  id          String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String?                   @map("campaign_id") @db.Uuid
  recipientId String?                   @map("recipient_id") @db.Uuid
  contactId   String?                   @map("contact_id") @db.Uuid
  eventType   String                    @map("event_type")
  metadata    Json                      @default("{}")
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign    EmailCampaignOp?          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient   EmailCampaignRecipientOp? @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  contact     EmailContactOp?           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([recipientId])
  @@index([contactId])
  @@index([eventType])
  @@map("email_events")
}

model EmailSuppressionOp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  reason    String
  source    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("email_suppressions")
}

model EmailInboundMessageOp {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId  String?         @map("contact_id") @db.Uuid
  fromEmail  String          @map("from_email")
  subject    String?
  body       String?
  receivedAt DateTime?       @map("received_at") @db.Timestamptz(6)
  rawPayload Json?           @map("raw_payload")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  contact    EmailContactOp? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@map("email_inbound_messages")
}

model EmailSendSettingsOp {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyLimit          Int      @default(25) @map("daily_limit")
  batchSize           Int      @default(5) @map("batch_size")
  minSecondsBetweenSends Int   @default(60) @map("min_seconds_between_sends")
  enabled             Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("email_send_settings")
}
