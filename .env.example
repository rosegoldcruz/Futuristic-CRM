APP_BASE_URL=https://crm.vulpinehomes.com
PORT=3101

DATABASE_URL=postgresql://vulpine_command_center_user:change-me@localhost:5432/vulpine_command_center?schema=public

# Auth.js + Zitadel OIDC
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://crm.vulpinehomes.com
ZITADEL_ISSUER=https://your-instance.zitadel.cloud
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# First admin: auto-promoted to OWNER + ACTIVE on Zitadel sign-in
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com

SEND_LAYER_PROVIDER=DRY_RUN
EMAIL_DRY_RUN=true

N8N_WEBHOOK_URL=
N8N_API_KEY=